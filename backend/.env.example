# ================================================================
# 資格スケジュール — バックエンド環境変数テンプレート
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
# ================================================================

# ================================================================
# データベース (PostgreSQL)
# ================================================================
# Neon: https://neon.tech でプロジェクト作成後に接続文字列を取得
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_SSL=true

# ================================================================
# 認証
# ================================================================
# openssl rand -base64 64 で生成してください（本番では必須）
JWT_SECRET=change-me-to-a-random-64-char-string

# ================================================================
# アプリ設定
# ================================================================
NODE_ENV=development
PORT=3001

# ================================================================
# CORS（本番ではフロントエンドのURLを指定）
# ================================================================
CORS_ORIGIN=http://localhost:3000

# ================================================================
# フロントエンドURL（メール内リンク・Stripe redirect用）
# ================================================================
APP_URL=http://localhost:3000

# ================================================================
# Stripe (課金)
# ================================================================
# https://dashboard.stripe.com/apikeys
# テスト: sk_test_xxxx / 本番: sk_live_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx

# Webhookエンドポイント登録後に取得
# https://dashboard.stripe.com/webhooks
# イベント: checkout.session.completed, invoice.payment_succeeded,
#           invoice.payment_failed, customer.subscription.updated,
#           customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Stripe ダッシュボード → 製品 で各プランのPriceを作成後に設定
# 月額 ¥480（1ヶ月の定期課金）
STRIPE_PRICE_MONTHLY=price_xxxx
# 3ヶ月 ¥1,380
STRIPE_PRICE_QUARTERLY=price_xxxx
# 6ヶ月 ¥2,640
STRIPE_PRICE_BIANNUAL=price_xxxx
# 年額 ¥4,560
STRIPE_PRICE_ANNUAL=price_xxxx

# ================================================================
# Web Push通知 (VAPID)
# ================================================================
# 生成コマンド: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=xxxx
VAPID_PRIVATE_KEY=xxxx
VAPID_SUBJECT=mailto:support@yourdomain.com

# ================================================================
# メール送信 — どちらか1つを設定
# ================================================================

# --- 推奨: Resend (https://resend.com) ---
# 無料プラン: 100通/日
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=noreply@yourdomain.com

# --- 代替: Gmail SMTP ---
# 2段階認証 + アプリパスワードが必要
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your@gmail.com

# ================================================================
# 管理者初期設定
# ================================================================
# 初回起動時に作成される管理者アカウント
# 本番では必ず変更してください
ADMIN_INITIAL_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=change-me-immediately
